rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = any authenticated user (only one admin account exists)
    function isAdmin() {
      return request.auth != null;
    }

    // Therapists: admin full control; public can read; therapists can update own profile fields
    match /therapists/{therapistId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admin: full update. Therapist (no Firebase auth): can only touch safe profile fields
      allow update: if isAdmin()
        || request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['available','name','bio','speciality','workStart','workEnd','workingHours','imageUrl','updatedAt','phone','fcmToken','sessionActive','lastActiveAt','onDuty','dutyStartedAt','locationUpdatedAt','location','emergencyContacts']);
    }

    // Gallery tokens: admin full control; clients can read to validate & update name/phone
    match /galleryTokens/{tokenId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['clientName', 'clientPhone', 'used']);
    }

    // View counts per (tokenId_therapistId): clients read/write for tracking
    match /viewCounts/{countId} {
      allow read, write: if true;
    }

    // View logs: clients can create; admin can read
    match /viewLogs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Bookings: clients create; therapists + admin read & update status
    match /bookings/{bookingId} {
      allow create: if true;
      allow read:   if true;
      allow update: if true;   // therapist accepts/declines; admin views
      allow delete: if isAdmin();
    }

    // Earnings: therapists add/read/delete their own session earnings
    match /earnings/{earnId} {
      allow read, write: if true;
    }

    // Attendance: therapists write their own records (duty on/off + session count);
    // admin can read all. Doc IDs follow pattern: {therapistDocId}_{YYYY-MM-DD}
    match /attendance/{attendId} {
      allow read:          if true;                // admin + therapist can read
      allow create, update: if true;               // therapist portal writes without Firebase auth
      allow delete:        if isAdmin();
    }

    // Tracking links: client-facing live location tokens (no phone exposed)
    match /trackingLinks/{token} {
      allow read:                   if true;       // client opens track.html?t=TOKEN
      allow create, update, delete: if isAdmin();  // only admin generates/deactivates
    }

    // App config: admin writes (force refresh signal); therapists read
    match /config/{docId} {
      allow read:             if true;
      allow create, update:   if isAdmin();
    }

    // Chat: admin ↔ therapist real-time messaging
    // Metadata doc (chats/{therapistDocId}): last message, unread counts
    match /chats/{therapistDocId} {
      allow read, write: if true;
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
