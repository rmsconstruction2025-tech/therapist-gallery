# Copy this file to .env and fill in your Firebase project values
# Get these from Firebase Console > Project Settings > Your apps

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Admin login credentials (must match a Firebase Auth user you create)
VITE_ADMIN_EMAIL=admin@admin.com
VITE_ADMIN_PASSWORD=admin123

# Admin WhatsApp number for "Book Now" button (include country code, no +)
VITE_ADMIN_WHATSAPP=919999999999
